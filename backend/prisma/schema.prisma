generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String     @id @default(cuid())
  name                    String?
  email                   String?    @unique
  password                String?
  image                   String?
  provider                String     @default("local")
  providerId              String?    @unique
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  refreshToken            String?
  resetToken              String?
  resetTokenExpiry        DateTime?
  role                    String     @default("user")
  isVerified              Boolean    @default(false)
  phone                   String?
  verificationTokenExpiry DateTime?
  verificationTokenHash   String?
  CartItem                CartItem[]
  cartLines               CartLine[]
  orders                  Order[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                               String                 @id @default(cuid())
  name                             String
  description                      String?
  price                            Float
  stock                            Int                    @default(0)
  category                         String
  imageUrl                         String?
  cloudinaryPublicId               String? // Cloudinary public ID for image deletion
  isActive                         Boolean                @default(true)
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt
  sku                              String?
  supportLevel                     String? // Bronze, Silver, Gold, Platinum
  packSize                         Int? // 3, 4, 7, 12
  isPackProduct                    Boolean                @default(false) // True for Gold/Platinum Supporter packs
  packType                         String? // "gold" or "platinum" for pack products
  nutritionFactsUrl                String? // URL to nutrition facts image/PDF (deprecated - use nutritionFacts relation)
  nutritionFactsCloudinaryPublicId String? // Cloudinary public ID for nutrition facts (deprecated - use nutritionFacts relation)
  CartItem                         CartItem[]
  orderItems                       OrderItem[]
  productFlavors                   ProductFlavor[]
  variations                       ProductVariation[]
  nutritionFacts                   ProductNutritionFact[]

  @@index([category])
  @@index([isActive])
  @@index([sku])
  @@index([supportLevel])
  @@index([packSize])
}

model ProductFlavor {
  id        String  @id @default(cuid())
  productId String
  flavorId  String
  quantity  Int
  flavor    Flavor  @relation(fields: [flavorId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, flavorId])
  @@index([productId])
  @@index([flavorId])
}

model ProductVariation {
  id         String                   @id @default(cuid())
  productId  String
  name       String // e.g., "Sour Best Sellers", "Sweet Best Sellers", "Traditional"
  sku        String?
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  product    Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductVariationImage[]
  flavors    ProductVariationFlavor[]
  orderItems OrderItem[]

  @@unique([productId, name])
  @@index([productId])
  @@index([isActive])
  @@index([sku])
}

model ProductVariationImage {
  id                 String           @id @default(cuid())
  variationId        String
  imageUrl           String
  cloudinaryPublicId String? // Cloudinary public ID for image deletion
  isDefault          Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  variation          ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@index([variationId])
  @@index([isDefault])
}

model ProductVariationFlavor {
  id          String           @id @default(cuid())
  variationId String
  flavorId    String
  quantity    Int
  flavor      Flavor           @relation(fields: [flavorId], references: [id], onDelete: Cascade)
  variation   ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@unique([variationId, flavorId])
  @@index([variationId])
  @@index([flavorId])
}

model ProductNutritionFact {
  id                 String   @id @default(cuid())
  productId          String
  fileUrl            String // URL to nutrition facts image/PDF
  cloudinaryPublicId String? // Cloudinary public ID for file deletion
  fileName           String? // Original file name
  fileType           String? // File type: "image" or "pdf"
  displayOrder       Int      @default(0) // Order for display
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([displayOrder])
}

model Order {
  id              String   @id @default(cuid())
  userId          String?
  guestId         String?
  guestEmail      String?
  status          String   @default("pending")
  total           Float
  shippingAddress Json?
  paymentStatus   String   @default("pending")
  orderNotes      String?
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Shipping fields
  shipmentId       String?
  trackingNumber   String?
  trackingUrl      String?
  shippingLabelUrl String?
  shippingStatus   String? @default("pending")
  shippingCarrier  String?
  shippingService  String?
  shippingCost     Float?
  shippingError    String?

  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([userId])
  @@index([guestId])
  @@index([guestEmail])
  @@index([status])
  @@index([paymentStatus])
  @@index([trackingNumber])
  @@index([shippingStatus])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String? // Made optional for custom packs
  variationId String? // Product variation ID
  quantity    Int
  price       Float
  total       Float
  createdAt   DateTime @default(now())

  // Custom pack fields
  flavorIds      String[] // For custom packs
  customPackName String? // For custom packs

  // Relations
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?          @relation(fields: [productId], references: [id])
  variation ProductVariation? @relation(fields: [variationId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variationId])
  @@index([flavorIds])
}

model Flavor {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  aliases                 String[] // for search & import cleaning
  imageUrl                String? // Flavor image URL
  cloudinaryPublicId      String? // Cloudinary public ID for image deletion
  active                  Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  inventory               FlavorInventory?
  packRecipeItems         PackRecipeItem[]
  productFlavors          ProductFlavor[]
  productVariationFlavors ProductVariationFlavor[]

  @@index([active])
}

model PackRecipe {
  id        String           @id @default(cuid())
  title     String
  kind      String
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  cartLines CartLine[]
  items     PackRecipeItem[]

  @@index([kind])
  @@index([active])
}

model PackRecipeItem {
  id           String     @id @default(cuid())
  packRecipeId String
  flavorId     String
  quantity     Int
  flavor       Flavor     @relation(fields: [flavorId], references: [id])
  packRecipe   PackRecipe @relation(fields: [packRecipeId], references: [id], onDelete: Cascade)

  @@unique([packRecipeId, flavorId])
  @@index([packRecipeId])
  @@index([flavorId])
}

model FlavorInventory {
  id          String   @id @default(cuid())
  flavorId    String   @unique
  onHand      Int      @default(0)
  reserved    Int      @default(0)
  safetyStock Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  flavor      Flavor   @relation(fields: [flavorId], references: [id])

  @@index([flavorId])
}

model CartLine {
  id         String      @id @default(cuid())
  userId     String?
  guestId    String?
  productId  String
  recipeId   String?
  quantity   Int
  unitPrice  Float
  sku        String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  flavorIds  String[]
  packRecipe PackRecipe? @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([guestId])
  @@index([productId])
  @@index([recipeId])
  @@index([flavorIds])
}

model CartItem {
  id              String   @id
  userId          String
  title           String
  imageUrl        String?
  stikersImgeUrl  String[]
  stikersName     String[]
  size            String?
  sizeAndQuantity Json?
  colorsName      String?
  colorsCode      String?
  options         Json
  quantity        Int
  total           Float
  orderNotes      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  productId       String?
  recipeId        String?
  sku             String
  unitPrice       Float
  flavorIds       String[]
  Product         Product? @relation(fields: [productId], references: [id])
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([flavorIds])
  @@index([productId])
  @@index([recipeId])
  @@index([userId])
}

// Trackdesk Tracking Models
model Website {
  id          String          @id @default(cuid())
  name        String
  domain      String?
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  events      TrackingEvent[]
  clicks      ReferralClick[]
  orders      ReferralOrder[]

  @@index([domain])
}

model ReferralCode {
  id             String          @id @default(cuid())
  code           String          @unique
  userId         String? // Affiliate user ID
  isActive       Boolean         @default(true)
  commissionRate Float           @default(0.1) // Commission rate (0.1 = 10%)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clicks         ReferralClick[]
  orders         ReferralOrder[]

  @@index([code])
  @@index([userId])
  @@index([isActive])
}

model TrackingEvent {
  id        String   @id @default(cuid())
  websiteId String
  sessionId String?
  userId    String?
  event     String // event name (page_view, click, etc.)
  data      Json? // event data
  page      Json? // page info
  device    Json? // device info
  browser   Json? // browser info
  timestamp DateTime @default(now())
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([sessionId])
  @@index([userId])
  @@index([event])
  @@index([timestamp])
}

model ReferralClick {
  id           String       @id @default(cuid())
  referralCode String
  websiteId    String
  url          String?
  referrer     String?
  userAgent    String?
  ipAddress    String?
  timestamp    DateTime     @default(now())
  website      Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  referral     ReferralCode @relation(fields: [referralCode], references: [code], onDelete: Cascade)

  @@index([referralCode])
  @@index([websiteId])
  @@index([timestamp])
}

model ReferralOrder {
  id           String       @id @default(cuid())
  referralCode String
  websiteId    String
  orderId      String
  orderValue   Float
  currency     String       @default("USD")
  commission   Float? // Calculated commission
  status       String       @default("pending") // pending, paid, cancelled
  timestamp    DateTime     @default(now())
  website      Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  referral     ReferralCode @relation(fields: [referralCode], references: [code], onDelete: Cascade)

  @@index([referralCode])
  @@index([websiteId])
  @@index([orderId])
  @@index([status])
  @@index([timestamp])
}

// Email Subscription Model
model EmailSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  source    String? // Where they subscribed from (e.g., "footer", "checkout")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([isActive])
  @@index([createdAt])
}

// Stripe Event tracking for idempotency
model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}
